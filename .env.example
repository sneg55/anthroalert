# ======================
# REQUIRED - Smart Money Alerts
# ======================

# Nansen API key (get from https://app.nansen.ai/)
NANSEN_API_KEY=your_nansen_api_key

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token

# Telegram Chat ID
# - Personal chat: your numeric user ID (e.g., 123456789)
# - Channel: -100xxxxxxxxxx (get from @userinfobot or forwarding message)
# - Group: negative number (e.g., -987654321)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ======================
# OPTIONAL - Trailing Stop Bot
# ======================

# Hyperliquid private key (for automated position management)
# ⚠️ Use a dedicated trading wallet, not your main wallet
HYPERLIQUID_PRIVATE_KEY=0x...

# ======================
# OPTIONAL - Additional Outputs
# ======================

# Discord webhook for alerts (alternative to Telegram)
DISCORD_WEBHOOK_URL=

# Anthropic API key (only for experimental agent system in agents/)
ANTHROPIC_API_KEY=
